# Asistenti.al — Cloud Run environment variables
#
# Set each of these in the Cloud Run service:
#   Console: Cloud Run → asistenti-backend → "Edit & Deploy New Revision"
#            → Variables & Secrets → Environment variables
#   CLI:     gcloud run services update asistenti-backend \
#              --region us-central1 \
#              --set-env-vars KEY=value,KEY2=value2

# Your Google Cloud project ID. Find it in the GCP console header
# (next to "Google Cloud") or run: `gcloud config get-value project`
GOOGLE_CLOUD_PROJECT=

# Region where Vertex AI and the RAG corpus live. Must match the
# region you used when creating the corpus. Default: us-central1.
GOOGLE_CLOUD_LOCATION=us-central1

# Full resource name of the RAG corpus created by `npm run ingest`.
# After the first ingest run, the corpus name is printed in the
# script's "Corpus:" line, e.g.
#   projects/123/locations/us-central1/ragCorpora/4567890123
# You can also list them: `gcloud ai rag-corpora list --region=us-central1`
VERTEX_RAG_CORPUS=

# Gemini model used for generation. Keep the default unless you have a
# reason to change it. Other options: gemini-1.5-pro, gemini-2.0-flash.
VERTEX_MODEL=gemini-1.5-flash

# Always "production" for the deployed service.
NODE_ENV=production

# Optional: comma-allowed origin override. Defaults already allow
# localhost:5173 and *.web.app / *.firebaseapp.com — set this only if
# you serve the frontend from a custom domain.
# CORS_ORIGIN=https://your-custom-domain.com
