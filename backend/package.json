{
  "name": "asistenti-backend",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "nodemon --watch src --ext ts --exec \"ts-node src/index.ts\"",
    "ingest": "ts-node scripts/ingest.ts",
    "typecheck": "tsc --noEmit",
    "deploy": "gcloud run deploy asistenti-backend --source . --region us-central1 --allow-unauthenticated --min-instances 1 --memory 512Mi --port 8080"
  },
  "dependencies": {
    "@google-cloud/aiplatform": "^6.8.0",
    "@google-cloud/vertexai": "^1.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "google-auth-library": "^10.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
